# API key solo en backend — nunca en la app móvil
#
# Celular físico (Expo Go): IP LAN del host en la red Wi‑Fi
#   EXPO_PUBLIC_API_URL=http://192.168.1.84:8001
#
# Emulador Android:
#   EXPO_PUBLIC_API_URL=http://10.0.2.2:8001
#
# Sin API local (Render — funciona en cualquier dispositivo):
#   EXPO_PUBLIC_API_URL=https://scanterms-api.onrender.com
#
# Tras modificar este archivo: npx expo start -c
EXPO_PUBLIC_API_URL=https://scanterms-api.onrender.com
